# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Authentication ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_byte_random_hex_secret_here
JWT_EXPIRE=7d

# ─── Email (for admin OTP reset via Brevo) ───────────────────────────────────
EMAIL_USER=your_gmail_address@gmail.com
BREVO_API_KEY=your_brevo_api_key_here

# ─── Admin Credentials (HASHES ONLY - Do Not Put Raw Passwords Here) ──────────
# Use server/scripts/generateHash.js to create these hashes
SUPER_ADMIN_EMAIL=aayushgupta.srm.540@gmail.com
SUPER_ADMIN_PASSWORD_HASH=your_bcrypt_hash_here
ADMIN_EMAIL=srmclasses01@gmail.com
ADMIN_PASSWORD_HASH=your_bcrypt_hash_here

# ─── Email (for student OTP via Resend) ──────────────────────────────────────
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL='Your App Name <otp@yourdomain.com>'

# ─── Cloudinary (file storage) ────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ─── URLs ─────────────────────────────────────────────────────────────────────
BACKEND_URL=https://your-backend-url.onrender.com
FRONTEND_URL=https://your-frontend-url.vercel.app

# ─── Scalability / Ops ────────────────────────────────────────────────────────
# Set REDIS_URL to enable distributed rate limiting across instances.
# Get a free Redis URL from: https://upstash.com or https://redis.com/try-free/
REDIS_URL=your_redis_url_here
# Set CRON_ENABLED=false on non-worker instances.
CRON_ENABLED=true

# ─── SMS OTP (optional — for mobile OTP via Fast2SMS) ─────────────────────────
# Get API key from: https://www.fast2sms.com/
FAST2SMS_API_KEY=your_fast2sms_api_key_here
